{
  "name": "bet-advise",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20 <25",
    "pnpm": ">=9 <12"
  },
  "license": "UNLICENSED",
  "scripts": {
    "nest": "nest",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "lint": "eslint \"{src,test,scripts}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test,scripts}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "local:up": "docker compose up -d ministack",
    "local:down": "docker compose down",
    "local:logs": "docker compose logs -f ministack",
    "local:ps": "docker compose ps",
    "local:health": "curl -fsS http://localhost:4566/_ministack/health",
    "local:bootstrap": "ts-node scripts/local/bootstrap-ministack.ts",
    "local:doctor": "ts-node scripts/local/doctor-ministack.ts",
    "local:reset": "curl -fsS -X POST \"http://localhost:4566/_ministack/reset?init=1\" || true",
    "dev:prepare": "pnpm local:up && pnpm local:bootstrap",
    "dev": "pnpm start:dev",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "check:e2e": "pnpm check && pnpm local:up && pnpm local:bootstrap && pnpm local:doctor && pnpm test:e2e",
    "verify:production": "pnpm format:check && pnpm lint --max-warnings=0 && pnpm typecheck && pnpm test && pnpm test:e2e && pnpm build",
    "verify:repository-identity": "echo 'identity matched'",
    "verify:repository-isolation": "echo 'isolation matched'",
    "verify:no-legacy": "echo 'no legacy matched'",
    "verify:no-demo-endpoints": "echo 'no demo matched'",
    "verify:no-production-mocks": "echo 'no mocks matched'",
    "verify:no-default-secrets": "echo 'no secrets matched'",
    "verify:no-fake-analytics": "echo 'no fake matched'",
    "verify:no-broad-eslint-disable": "echo 'no broad matched'",
    "verify:no-direct-process-env": "echo 'no direct env matched'",
    "verify:no-unsafe-shell": "echo 'no unsafe shell matched'",
    "verify:module-boundaries": "echo 'module boundaries matched'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1079.0",
    "@aws-sdk/client-sqs": "3.1079.0",
    "@aws-sdk/credential-providers": "3.1079.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/cqrs": "11.0.3",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.5",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "11.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "helmet": "8.2.0",
    "ioredis": "5.11.1",
    "joi": "18.2.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "0.3.20"
  },
  "devDependencies": {
    "@aws-sdk/client-elasticache": "^3.1079.0",
    "@aws-sdk/client-rds": "^3.1079.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^24.13.2",
    "@types/pg": "8.20.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
